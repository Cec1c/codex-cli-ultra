{
  "name": "codex-cli-ultra",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "node scripts/build-executor.mjs",
    "test": "node --test",
    "text:audit": "node scripts/audit-visible-text.mjs",
    "ftl:audit": "node scripts/audit-ftl-contract.mjs",
    "catalog:extract": "node src/cli.mjs catalog extract",
    "language:validate": "node src/cli.mjs language validate --pack packages/languages/zh-CN --catalog research/codex-0.144.5/tui-messages.jsonl --template templates/languages/messages.en-US.ftl",
    "adapter:apply": "node src/cli.mjs adapter apply",
    "adapter:revert": "node src/cli.mjs adapter revert",
    "doctor": "node src/cli.mjs doctor"
  },
  "dependencies": {
    "@fluent/bundle": "0.19.1",
    "@fluent/syntax": "0.19.0",
    "yauzl": "3.4.0"
  },
  "devDependencies": {
    "esbuild": "0.25.6",
    "yazl": "3.3.1"
  }
}
